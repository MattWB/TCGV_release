---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/page/PageHero.astro";
import PageSection from "../components/page/PageSection.astro";
import JoinSection from "../components/page/JoinSection.astro";
import TarifPlanCard from "../components/tarifs/TarifPlanCard.astro";

// DATA
import { 
  hero, 
  introParagraph, 
  pricingPlans, 
  familyPlans, 
  benefits, 
  practical } from "../data/tarifsContent";

---

<BaseLayout
  title="Tarifs & Adhésions — TCGV"
  description="Tarifs et adhésions du Tennis Club du Grand Versailles : formules individuelles et familiales, avantages inclus et informations pratiques."
>
  <!-- HERO -->
  <PageHero
    title={hero.title}
    subtitle={hero.subtitle}
    watermark={hero.watermark}
    watermarkColor="text-grey/30"
    variant="premium"
  />

  <!-- INTRO -->
  <PageSection
    title="Choisissez votre formule"
    subtitle={introParagraph.text}
    titleClass="text-clubwhite"
    subtitleClass="text-clubwhite italic"
    bgClass="bg-club/90"
    align="center"
    tone="default"
    premiumBg="none"
  >
  </PageSection>

  <!-- PRICING — INDIVIDUEL -->
  <PageSection
    title="Formules individuelles"
    subtitle=""
    watermark="Premium"
    tone="muted"
    premiumBg="none"
  >
    <div class="mx-auto mt-4 lg:mt-8 grid max-w-7xl gap-8 md:grid-cols-3">
      {pricingPlans.map((plan) => (
        <div class="reveal reveal--card">
          <TarifPlanCard
            plan={plan}
            ctaHref="/inscriptions"
            defaultCtaClass="tcgv-btn--black"
            highlightCtaClass="tcgv-btn--service-outline"
            showHighlightBadge={true}
            showSubtitleWhenNotHighlighted={true}
            minHeightClass="min-h-[560px]"
          />
        </div>
      ))}
    </div>
  </PageSection>

  <!-- PRICING — FAMILLE -->
  <PageSection
    title="Formules familiales"
    subtitle=""
    watermark="Famille"
    tone="muted"
  >
    <div class="mx-auto mt-4 lg:mt-8 grid max-w-5xl gap-8 md:grid-cols-2">
      {familyPlans.map((plan) => (
        <div class="reveal reveal--card">
          <TarifPlanCard
            plan={plan}
            ctaHref="/inscriptions"
            defaultCtaClass="tcgv-btn--black"
            highlightCtaClass="tcgv-btn--service"
          />
        </div>
      ))}
    </div>
  </PageSection>

  <!-- BENEFITS -->
  <PageSection
    title="Tout ce qu’il faut savoir"
    subtitle=""
    align="left"
    tone="premium"
    premiumBg="none"
    premiumOverlay="club"
    overlayDir="to-tr"
    overlayStrength="soft"
  >
    <div class="mx-auto mt-4 lg:mt-8 grid max-w-6xl gap-4 lg:gap-8 md:grid-cols-2 lg:grid-cols-3">
      {benefits.map((b) => (
        <div class="reveal reveal--card">
          <article class="card-premium group h-full p-4 md:p-6">
            <h3 class="text-lg font-semibold tracking-tight group-hover:text-club transition-colors">
              {b.title}
            </h3>
            <p class="mt-3 text-sm/6 text-muted-foreground">
              {b.description}
            </p>
          </article>
        </div>
      ))}
    </div>
  </PageSection>

  <!-- PRACTICAL INFO -->
  <PageSection 
    title={practical.title}
    watermark="Informations"
    align="left"
  >
    <div class="reveal reveal--body mx-auto mt-4 lg:mt-8 max-w-3xl">
      <div class="card-premium p-4 md:p-6 overflow-hidden">
        <div class="space-y-8">
          {practical.blocks.map((block) => (
            <section>
              <h3 class="text-xl font-semibold tracking-tight">{block.title}</h3>

              {block.body && (
                <p class="mt-3 text-sm/6 text-muted-foreground">
                  {block.body}
                </p>
              )}

              {block.list && (
                <ul class="mt-4 list-disc pl-5 text-sm/6 text-muted-foreground space-y-2">
                  {block.list.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              )}
            </section>
          ))}
        </div>
      </div>
    </div>
  </PageSection>

  <JoinSection
    title="Rejoignez le club"
    bgKey="club"
    body="Découvrez nos formules et construisez votre pratique au rythme qui vous convient."
    note="Une question ? • Réponse sous 48h"
    ctas={[
      { label: "Devenir membre", href: "/inscriptions", variant: "primary"},
      { label: "Nous contacter", href: "/contact", variant: "alt" }
    ]}
  />
</BaseLayout>

