---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/page/PageHero.astro";
import PageSection from "../components/page/PageSection.astro";
import JoinSection from "../components/page/JoinSection.astro";

// ICONS
import IconSparks from "@components/icons/IconSparks.astro";

// DATA
import {
  partenairesContent as data,
  partenairesSeo as seo,
} from "../data/partenairesContent";

const premiumCount = data.premium.items.length;
const officialCount = data.official.items.length;
const supportersCount = data.supporters.items.length;
---

<BaseLayout title={seo.title} description={seo.description}>
  <PageHero
    title={data.hero.title}
    subtitle={data.hero.subtitle}
    variant="premium"
    watermark={data.hero.watermark}
    watermarkColor="text-grey/30"
  >
  </PageHero>

  <PageSection
    title={data.intro.title}
    subtitle={data.intro.subtitle}
    titleClass="text-clubwhite"
    subtitleClass="text-clubwhite italic"
    bgClass="bg-club/90"
    align="center"
    tone="default"
    premiumBg="none"
  >
    <div class="mt-8">
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <span class="tcgv-pill tcgv-pill--overlay-primary border-transparent text-primary">Premium : <strong class="ml-1 text-primary">{premiumCount}</strong></span>
        <span class="tcgv-pill tcgv-pill--overlay-primary border-transparent text-club">Officiels : <strong class="ml-1 text-club">{officialCount}</strong></span>
        <span class="tcgv-pill tcgv-pill--overlay-primary border-transparent text-club">Supporters : <strong class="ml-1 text-club">{supportersCount}</strong></span>
      </div>
    </div>
  </PageSection>

  <!-- PREMIUM -->
  <PageSection
    id="premium"
    title={data.premium.title}
    tone="default"
    align="left"
    watermark={data.premium.watermark}
    watermarkClass="text-[14vw] opacity-10"
  >
    <div class="relative mt-4 lg:mt-8 reveal reveal--title">
      <div class="grid gap-4 lg:grid-cols-3">
        {data.premium.items.map((partner) => (
          <article class="card-premium group p-6 border-primary/25 hover:border-primary">
            <div class="flex items-center justify-center gap-2 rounded-xl border border-primary bg-primary text-clubwhite backdrop-blur-[2px] px-4 py-3">
              <IconSparks class="tcgv-icon" />
              <span class="text-sm font-semibold">Premium Partner</span>
            </div>

            <div class="mt-6 grid gap-5">
              <div class="mx-auto grid h-24 w-full place-items-center overflow-hidden">
                <partner.Logo class="h-10 w-auto max-w-full" />
              </div>

              <header class="text-center">
                <h3 class="text-xl font-semibold group-hover:text-primary transition-colors">
                  {partner.name}
                </h3>
                <span class="tcgv-pill tcgv-pill--primary tcgv-pill--xs mt-2">{partner.category}</span>
              </header>

              <p class="text-sm text-muted-foreground leading-relaxed text-center">
                {partner.description}
              </p>

              <div class="pt-4 border-t border-clubblack/10">
                <p class="text-xs font-semibold text-muted-foreground text-center">Contributions :</p>
                <ul class="mt-3 space-y-2 text-sm">
                  {partner.contributions.map((c) => (
                    <li class="flex items-center gap-2">
                      <span class="h-1.5 w-1.5 rounded-full bg-primary" />
                      <span>{c}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </PageSection>

  <!-- OFFICIELS -->
  <PageSection
    id="officiels"
    title={data.official.title}
    tone="muted"
    align="left"
    watermark={data.official.watermark}
    watermarkClass="text-[16vw] opacity-10"
  >
    <div class="relative mt-4 lg:mt-8 reveal reveal--title">
      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3 reveal reveal--card">
        {data.official.items.map((partner) => (
          <article class="card-premium group p-6">
            <div class="mx-auto grid h-16 w-full place-items-center overflow-hidden">
              <partner.Logo class="h-10 w-auto max-w-full" />
            </div>

            <header class="mt-4 text-center">
              <h3 class="text-lg font-semibold group-hover:text-club transition-colors">
                {partner.name}
              </h3>
              <p class="mt-1 text-xs text-muted-foreground">{partner.category}</p>
            </header>

            <p class="mt-3 text-sm text-muted-foreground leading-relaxed text-center">
              {partner.description}
            </p>
          </article>
        ))}
      </div>
    </div>
  </PageSection>

  <!-- SUPPORTERS -->
  <PageSection
    id="supporters"
    title={data.supporters.title}
    tone="premium"
    align="left"
    premiumBg="none"
    premiumOverlay="club"
    overlayDir="to-top"
    overlayStrength="soft"
  >
    <div class="relative mt-4 lg:mt-8 reveal reveal--title">
      <div class="card-premium p-6 sm:p-8">
        <div class="grid grid-cols-2 gap-4 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {data.supporters.items.map((s) => (
            <div class="grid place-items-center gap-2">
              <div class="grid h-16 w-16 place-items-center rounded-full border border-clubblack/10 bg-clubwhite">
                <span class="text-sm font-semibold text-club">{s.logo}</span>
              </div>
              <p class="text-xs text-center text-muted-foreground leading-tight">{s.name}</p>
            </div>
          ))}
        </div>
      </div>

      <p class="reveal reveal--body mt-6 text-center text-sm text-muted-foreground">
        {data.supporters.thanks}
      </p>
    </div>
  </PageSection>

  <!-- BENEFITS + PLANS -->
  <PageSection
    id="avantages"
    title={data.benefits.title}
    tone="default"
    align="left"
    watermark={data.benefits.watermark}
  >
    <div class="relative mt-4 lg:mt-8 reveal reveal--title">
      <div class="grid gap-4 md:grid-cols-2 reveal reveal--card">
        {data.benefits.items.map((b) => (
          <article class="card-premium p-6">
            <div class="flex items-start gap-3">
              <div class="grid h-12 w-12 place-items-center shrink-0 rounded-full transition-colors duration-300 bg-club/10 text-club/70 group-hover:text-club">
                <b.Icon class="tcgv-icon size-6" />
              </div>
              <div>
                <h3 class="text-lg font-semibold">{b.title}</h3>
                <p class="mt-2 text-sm text-muted-foreground leading-relaxed">{b.description}</p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="mt-10 p-y-6 sm:p-y-8 reveal reveal--card border-primary/20">
        <h3 class="text-xl font-semibold text-center">{data.plans.title}</h3>

        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {data.plans.items.map((p) => (
            <div class="card-premium rounded-2xl border border-clubblack/10 bg-clubwhite/70 backdrop-blur-[2px] p-6 text-center">
              <span class="tcgv-pill tcgv-pill--primary tcgv-pill--xs">{p.label}</span>
              <p class="mt-4 text-2xl leading-tight">{p.price}</p>
              <p class="mt-2 text-sm text-muted-foreground">{p.unit}</p>
            </div>
          ))}
        </div>

        <p class="mt-6 text-center text-sm text-muted-foreground">{data.plans.note}</p>
      </div>
    </div>
  </PageSection>

  <JoinSection
    title={data.joinSection.title}
    body={data.joinSection.body}
    note={data.joinSection.note}
    ctas={data.joinSection.ctas}
  />

</BaseLayout>
