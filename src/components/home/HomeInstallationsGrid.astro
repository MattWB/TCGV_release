---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import PageSection from "../page/PageSection.astro";
import ResponsiveImage from "../media/ResponsiveImage.astro";
import SlideshowCourts from "../SlideshowCourts.astro";
import { withBase } from "@utils/url";

interface InstallationItem {
  href: string;
  title: string;
  text: string;
  cta: string;
  image: ImageMetadata;
}

interface InstallationsSection {
  id: string;
  title: string;
  subtitle: string;
  backgroundImage: ImageMetadata;
  items: InstallationItem[];
}

interface Props {
  section: InstallationsSection;
}

const { section } = Astro.props;

const sectionBg1x = await getImage({
  src: section.backgroundImage,
  width: Math.min(960, section.backgroundImage.width),
  format: "webp",
  quality: 80,
});

const sectionBg2x = await getImage({
  src: section.backgroundImage,
  width: Math.min(1920, section.backgroundImage.width),
  format: "webp",
  quality: 80,
});

const sectionBgStyle = [
  `--tcgv-image-bg: url('${sectionBg1x.src}')`,
  `--tcgv-image-bg: -webkit-image-set(url('${sectionBg1x.src}') 1x, url('${sectionBg2x.src}') 2x)`,
  `--tcgv-image-bg: image-set(url('${sectionBg1x.src}') 1x, url('${sectionBg2x.src}') 2x)`,
].join("; ");
---

<PageSection
  id={section.id}
  title={section.title}
  subtitle={section.subtitle}
  tone="default"
  align="left"
  bgClass="bg-lb"
  style={sectionBgStyle}
>
  <div class="reveal reveal--media mt-5">
    <div class="relative w-full overflow-hidden rounded-2xl shadow min-h-[255px] aspect-[16/9] lg:aspect-[2/1] max-w-[800px] lg:max-w-full max-h-[55svh] m-auto">
      <SlideshowCourts />
    </div>
  </div>

  <div class="reveal reveal--body mt-4 lg:mt-12 grid gap-4 lg:gap-8 lg:grid-cols-3">
    {section.items.map((item) => (
      <div class="reveal reveal--card">
        <article class="card-premium border-0 group relative h-full overflow-hidden flex flex-col">
          <div class="relative overflow-hidden shrink-0">
            <ResponsiveImage
              src={item.image}
              alt={item.title}
              kind="card"
              class="w-full h-64 object-cover group-hover:scale-110 transition-all duration-450"
            />
            <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 tcgv-img-overlay-primary"></div>
          </div>

          <div class="flex flex-col flex-1 min-h-0 p-5">
            <h3 class="text-m">
              <span class="underline-animate from-left relative inline-block">
                {item.title}
              </span>
              <span class="block mt-3 mb-3 text-sm text-gray-500 group-hover:text-clubblack transition-all duration-450">
                {item.text}
              </span>
            </h3>

            <a href={withBase(item.href)} class="tcgv-btn tcgv-btn--cta tcgv-focus lg:mt-auto">
              {item.cta}
            </a>
          </div>
        </article>
      </div>
    ))}
  </div>
</PageSection>

