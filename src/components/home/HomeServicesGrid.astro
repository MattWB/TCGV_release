---
import type { ImageMetadata } from "astro";
import type { AstroIconComponent } from "../../types/icons";
import PageSection from "../page/PageSection.astro";
import ResponsiveImage from "../media/ResponsiveImage.astro";
import { withBase } from "@utils/url";

interface ServiceItem {
  href: string;
  title: string;
  text: string;
  cta: string;
  image: ImageMetadata;
  Icon: AstroIconComponent;
}

interface ServicesSection {
  id: string;
  title: string;
  subtitle: string;
  items: ServiceItem[];
}

interface Props {
  section: ServicesSection;
}

const { section } = Astro.props as Props;
---

<PageSection
  id={section.id}
  title={section.title}
  subtitle={section.subtitle}
  tone="default"
  align="left"
>
  <div class="reveal reveal--body mt-4 lg:mt-12 grid gap-4 lg:gap-8 lg:grid-cols-2 xl:grid-cols-4">
    {section.items.map((item) => (
      <div class="reveal reveal--card">
        <article class="card-premium group overflow-hidden flex flex-col h-full p-5">
          <div class="flex flex-row items-center">
            <div class="grid size-12 place-items-center rounded-full bg-primary/10 text-primary/70 transition-all duration-300 group-hover:bg-primary/15 group-hover:text-primary group-hover:scale-[1.03]">
              <item.Icon class="tcgv-icon size-6" aria-hidden="true" />
            </div>

            <div class="relative block w-24 h-16 ml-4 rounded-md overflow-hidden transition-all duration-450 ease-in-out">
              <ResponsiveImage
                src={item.image}
                alt={item.title}
                kind="thumb"
                widths={[96, 160]}
                sizes="96px"
                class="w-full h-full object-cover group-hover:scale-110 transition-all duration-450 ease-in-out"
              />
              <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 tcgv-img-overlay-primary"></div>
            </div>
          </div>

          <div class="mt-6 flex flex-col flex-1">
            <h3 class="text-m font-semibold tracking-tight transition-colors">
              <span class="relative inline-block">
                {item.title}
                <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-primary transition-all duration-300 group-hover:w-full"></span>
              </span>
            </h3>

            <p class="mt-3 mb-8 text-sm text-gray-500 group-hover:text-clubblack transition-all duration-450 ease-in-out">
              {item.text}
            </p>

            <a href={withBase(item.href)} class="tcgv-btn tcgv-btn--cta tcgv-focus mt-auto">
              {item.cta}
            </a>
          </div>
        </article>
      </div>
    ))}
  </div>
</PageSection>


