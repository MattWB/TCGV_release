---
import ResponsiveImage from "../components/media/ResponsiveImage.astro";

// ICONS
import IconChevron from "@components/icons/IconChevronRight.astro";

// IMAGES
import slide1 from "@assets/images/gallery/tcgv-gallery-slide-item1-1920.avif";
import slide2 from "@assets/images/gallery/tcgv-gallery-slide-item2-1920.avif";
import slide3 from "@assets/images/gallery/tcgv-gallery-slide-item3-1920.avif";
import slide4 from "@assets/images/gallery/tcgv-gallery-slide-item4-1920.avif";
import slide5 from "@assets/images/gallery/tcgv-gallery-slide-item5-1920.avif";

const slides = [
  slide1,
  slide2,
  slide3,
  slide4,
  slide5
]
---

<!-- FLOWBITE CAROUSEL -->
<div id="home-hero-carousel" class="relative h-full w-full" data-carousel="slide">
  <div class="relative h-full w-full overflow-hidden rounded-2xl">
    {slides.map((slide, index) => (
      <div
        class={`${index === 0 ? "" : "hidden"} duration-700 ease-in-out absolute inset-0`}
        data-carousel-item={index === 0 ? "active" : ""}
      >
        <ResponsiveImage
          src={slide}
          alt="Photo de la galerie d'images du TCGV"
          kind="hero-lcp"
          loading={index === 0 ? "eager" : "lazy"}
          class="w-full h-full object-cover object-center"
          format="avif"
        />
      </div>
    ))}
  </div>

  <div class="absolute z-50 left-1/2 -translate-x-1/2 bottom-4 flex items-center gap-3">
    {slides.map((_, index) => (
      <button
        class="tcgv-dot"
        data-carousel-slide-to={index}
        aria-label={`Slide ${index + 1}`}
        aria-current={index === 0 ? "true" : undefined}
      ></button>
    ))}
  </div>

  <button type="button" class="absolute top-0 left-0 z-50 grid place-items-center w-12 h-full px-2 text-white/90 hover:cursor-pointer" data-carousel-prev aria-label="Slide précédente"><span class="grid place-items-center w-9 h-9 rounded-full bg-black/25 ring-1 ring-white/15 backdrop-blur-sm rotate-180"><IconChevron class="tcgv-icon" aria-hidden="true" /></span></button>
  <button type="button" class="absolute top-0 right-0 z-50 grid place-items-center w-12 h-full px-2 text-white/90 hover:cursor-pointer" data-carousel-next aria-label="Slide suivante"><span class="grid place-items-center w-9 h-9 rounded-full bg-black/25 ring-1 ring-white/15 backdrop-blur-sm"><IconChevron class="tcgv-icon" aria-hidden="true" /></span></button>
</div>



