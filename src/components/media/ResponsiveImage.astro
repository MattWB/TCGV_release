---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Kind = "card" | "card-wide" | "thumb" | "icon" | "section" | "hero";
type ImgLoading = "eager" | "lazy" | "auto";

const PRESETS = {
  card: {
    widths: [320, 480, 800],
    sizes: "(max-width: 640px) 92vw, (max-width: 1024px) 45vw, 360px",
    loading: "lazy",
  },
  "card-wide": {
    widths: [480, 800, 1200],
    sizes: "(max-width: 640px) 92vw, (max-width: 1024px) 50vw, 620px",
    loading: "lazy",
  },
  thumb: {
    widths: [96, 160, 320],
    sizes: "(max-width: 640px) 24vw, 96px",
    loading: "lazy",
  },
  icon: {
    widths: [32, 48, 64],
    sizes: "20px",
    loading: "lazy",
  },
  section: {
    widths: [640, 960, 1600],
    sizes: "(max-width: 1024px) 100vw, 960px",
    loading: "lazy",
  },
  hero: {
    widths: [768, 1200, 1600],
    sizes: "100vw",
    loading: "eager",
  },
} as const;

type Props = {
  src: ImageMetadata;
  alt: string;
  kind?: Kind;
  widths?: number[];
  sizes?: string;
  loading?: ImgLoading;
  format?: "webp" | "avif" | "png" | "jpg" | "jpeg";
  class?: string;
};

const {
  src,
  alt,
  kind = "card",
  widths,
  sizes,
  loading,
  format = "webp",
  class: className = "w-full h-auto",
} = Astro.props;

const preset = PRESETS[kind];
const effectiveWidths = widths?.length ? widths : [...preset.widths];
const effectiveSizes = sizes ?? preset.sizes;
const effectiveLoading = loading ?? preset.loading;
---

<Image
  src={src}
  alt={alt}
  widths={effectiveWidths}
  format={format}
  sizes={effectiveSizes}
  loading={effectiveLoading}
  class={className}
/>
