---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

type Kind = "card" | "card-wide" | "thumb" | "icon" | "section" | "hero" | "hero-lcp";
type ImgLoading = "eager" | "lazy" | null | undefined;

const PRESETS = {
  card: {
    widths: [320, 480, 800],
    sizes: "(max-width: 640px) 92vw, (max-width: 1024px) 45vw, 360px",
    loading: "lazy",
  },
  "card-wide": {
    widths: [480, 800, 1200],
    sizes: "(max-width: 640px) 92vw, (max-width: 1024px) 50vw, 620px",
    loading: "lazy",
  },
  thumb: {
    widths: [96, 160, 320],
    sizes: "(max-width: 640px) 24vw, 96px",
    loading: "lazy",
  },
  icon: {
    widths: [32, 48, 64],
    sizes: "20px",
    loading: "lazy",
  },
  section: {
    widths: [640, 960, 1600],
    sizes: "(max-width: 1024px) 100vw, 960px",
    loading: "lazy",
  },
  hero: {
    widths: [640, 960, 1280, 1536],
    sizes: "100vw",
    loading: "eager",
  },
  "hero-lcp": {
    widths: [640, 960, 1200],
    sizes: "100vw",
    loading: "eager",
  },
} as const;

type Props = {
  src: ImageMetadata;
  alt: string;
  kind?: Kind;
  widths?: number[];
  sizes?: string;
  loading?: ImgLoading;
  format?: "webp" | "avif" | "png" | "jpg" | "jpeg";
  class?: string;
  fetchpriority?: "high" | "low" | "auto";
  decoding?: "sync" | "async" | "auto";
};

const {
  src,
  alt,
  kind = "card",
  widths,
  sizes,
  loading,
  format,
  class: className = "w-full h-auto",
  fetchpriority,
  decoding,
} = Astro.props;

const preset = PRESETS[kind] || PRESETS.card;

const effectiveWidths = widths?.length ? widths : [...preset.widths];
const effectiveSizes = sizes ?? preset.sizes;
const effectiveLoading = loading ?? preset.loading;
const effectiveFormat = format ?? (src.format === "avif" ? "avif" : undefined);
---

<Image
  src={src}
  alt={alt}
  widths={effectiveWidths}
  sizes={effectiveSizes}
  format={effectiveFormat}
  loading={effectiveLoading}
  fetchpriority={fetchpriority || (effectiveLoading === "eager" ? "high" : "auto")}
  decoding={decoding || (effectiveLoading === "eager" ? "sync" : "async")}
  class={className}
/>
