---
import IconShield from "@components/icons/IconShield.astro";

interface LegalItem {
  strong: string;
  text: string;
}

interface LegalBlock {
  title: string;
  items: LegalItem[];
  lastUpdate: string;
}

interface Props {
  legal: LegalBlock;
}

const { legal } = Astro.props;
---

<div class="mx-auto mt-8 max-w-4xl">
  <div class="reveal reveal--card card-premium still p-7 md:p-8">
    <h3 class="flex items-center gap-3 text-xl md:text-2xl font-semibold tracking-tight text-club">
      <span class="grid size-12 place-items-center rounded-full bg-club/10 text-club">
        <IconShield class="tcgv-icon size-6" aria-hidden="true" />
      </span>
      {legal.title}
    </h3>

    <div class="mt-6 space-y-4 text-[15px] md:text-base leading-7 text-muted-foreground">
      {legal.items.map((it) => (
        <p>
          <strong class="text-clubblack">{it.strong}</strong>
          {it.text}
        </p>
      ))}
    </div>
  </div>

  <div class="reveal reveal--body mt-10 text-center">
    <div class="mx-auto flex flex-col items-stretch gap-3 sm:flex-row sm:justify-center">
      <button
        type="button"
        class="tcgv-btn tcgv-btn--service-solid w-full sm:w-auto px-8 tcgv-focus"
        data-toast="pdf"
      >
        <span class="inline-flex items-center justify-center gap-2">
          Télécharger en PDF
        </span>
      </button>

      <a class="tcgv-btn tcgv-btn--alt w-full sm:w-auto px-8" href="#main">
        Remonter
      </a>
    </div>

    <p class="mt-6 text-sm text-muted-foreground">{legal.lastUpdate}</p>
  </div>
</div>
