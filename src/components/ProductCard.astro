---
import ResponsiveImage from "../components/media/ResponsiveImage.astro";
import type { ImageMetadata } from "astro";
import type { AstroIconComponent } from "../types/icons";

type Props = {
  imageSrc: ImageMetadata;
  name: string;
  price: string;
  description: string;
  categoryIcon?: AstroIconComponent;
  badge?: string;
};

const {
  imageSrc,
  name,
  price,
  description,
  categoryIcon: CategoryIcon,
  badge,
} = Astro.props as Props;
---

<article class="card-premium group overflow-hidden">
  <div class="relative aspect-[16/9] overflow-hidden bg-clubwhite">
    <ResponsiveImage
      src={imageSrc}
      alt={name}
      kind="card"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100 tcgv-img-overlay-ball"></div>

    {badge && (
      <div class="absolute left-3 top-3">
        <span class="tcgv-pill tcgv-pill--primary tcgv-pill--overlay-ball tcgv-pill--xs">{badge}</span>
      </div>
    )}

    {CategoryIcon && (
      <div class="absolute right-3 top-3">
        <span class="grid size-9 place-items-center rounded-full bg-ball">
          <CategoryIcon class="tcgv-icon size-6 text-clubblack" aria-hidden="true" />
        </span>
      </div>
    )}
  </div>

  <div class="p-5 md:p-6">
    <h3 class="relative text-lg font-semibold tracking-tight transition-colors">
      <span class="relative inline-block">
        {name}
        <span class="absolute -bottom-1 left-0 h-0.5 w-0 bg-ball transition-all duration-300 group-hover:w-full"></span>
      </span>
    </h3>
    <p class="mt-2 text-sm text-muted-foreground">{description}</p>
    <p class="mt-4 text-xl font-semibold">{price}</p>
  </div>
</article>
