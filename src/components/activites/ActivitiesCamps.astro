---
import type { ImageMetadata } from "astro";
import ResponsiveImage from "@components/media/ResponsiveImage.astro";
import { withBase } from "@utils/url";

interface Camp {
  season: string;
  period: string;
  description: string;
  ages: string;
  Icon: any;
  gradientClass: string;
}

interface Props {
  camps: Camp[];
  kidsCourseImg: ImageMetadata;
}

const { camps, kidsCourseImg } = Astro.props;
---

<div class="reveal reveal--media mx-auto mt-8 max-w-5xl overflow-hidden rounded-2xl shadow-xl">
  <div class="relative aspect-[21/9]">
    <ResponsiveImage
      src={kidsCourseImg}
      alt="Stages enfants"
      kind="section"
      class="absolute inset-0 h-full w-full object-cover"
    />
    <div class="absolute inset-0 tcgv-stage-overlay" />
  </div>
</div>

<div class="reveal reveal--card mt-12 mx-auto grid max-w-6xl gap-4 lg:gap-6 md:grid-cols-2 lg:grid-cols-4">
  {camps.map((camp) => (
    <article class="card-premium group overflow-hidden">
      <div class={`h-2 ${camp.gradientClass}`}></div>

      <div class="p-6 text-center">
        <div class={`mx-auto grid size-16 place-items-center rounded-full ${camp.gradientClass} tcgv-icon-bubble-soft transition-transform duration-300 group-hover:scale-[1.06]`}>
          <camp.Icon class="tcgv-icon size-8" />
        </div>

        <h3 class="mt-4 text-2xl font-semibold tracking-tight group-hover:text-primary transition-colors">
          {camp.season}
        </h3>
        <div class="mt-1 text-sm font-normal text-muted-foreground">
          {camp.period}
        </div>

        <p class="mt-4 text-sm/6 text-muted-foreground">
          {camp.description}
        </p>

        <div class="mt-5">
          <span class="tcgv-pill tcgv-pill--primary">{camp.ages}</span>
        </div>

        <div class="mt-6">
          <a class="tcgv-btn tcgv-btn--cta tcgv-focus" href={withBase("/contact")}>
            Nous contacter
          </a>
        </div>
      </div>
    </article>
  ))}
</div>

