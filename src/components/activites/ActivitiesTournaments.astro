---
import IconCalendar from "@components/icons/IconCalendar.astro";
import IconTarget from "@components/icons/IconTarget.astro";
import IconTrophy from "@components/icons/IconTrophy.astro";

interface Tournament {
  title: string;
  type: string;
  date: string;
  level: string;
  description: string;
}

interface Props {
  tournaments: Tournament[];
}

const { tournaments } = Astro.props;
---

<div class="mx-auto mt-8 max-w-4xl space-y-6">
  {tournaments.map((t) => (
    <div class="reveal reveal--card mb-4 lg:mb-8">
      <article class="card-premium group relative overflow-hidden">
        <div class="absolute inset-y-0 left-0 w-1 bg-primary transition-all duration-300 group-hover:w-2"></div>

        <div class="flex gap-4 p-6 pl-7">
          <div class="grid size-12 place-items-center rounded-full bg-primary/10 text-primary/70 group-hover:text-primary transition-all duration-300 group-hover:bg-primary/15">
            <IconTrophy class=" size-6" />
          </div>

          <div class="min-w-0 flex-1">
            <h3 class="text-lg font-semibold tracking-tight group-hover:text-primary transition-colors">
              {t.title}
            </h3>

            <div class="mt-2 flex flex-wrap gap-2">
              <span class="tcgv-pill tcgv-pill--primary text-xs">{t.type}</span>

              <span class="tcgv-pill tcgv-pill--soft text-xs inline-flex items-center gap-1">
                <IconCalendar class="size-3" />
                {t.date}
              </span>

              <span class="tcgv-pill tcgv-pill--muted text-xs inline-flex items-center gap-1">
                <IconTarget class="size-3" />
                {t.level}
              </span>
            </div>

            <p class="mt-3 text-sm/6 text-muted-foreground">
              {t.description}
            </p>
          </div>
        </div>
      </article>
    </div>
  ))}
</div>
